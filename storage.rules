rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'atividadesinfantilcontato@gmail.com';
    }

    match /debug-upload/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /public-write-test-connection.png {
      allow read, write: if isAdmin();
    }

    match /free-materials/{materialId}/{allFiles=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
